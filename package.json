{
  "name": "praesidium",
  "version": "0.1.0",
  "description": "Praesidium — a super large-scale tower defense game (web)",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "selftest": "npx -y tsx scripts/selftest.ts",
    "test:save": "npx -y tsx scripts/save-restore-test.ts",
    "balance:sim": "npx -y tsx scripts/balance-sim.ts",
    "release:audit": "npx -y tsx scripts/release-audit.ts",
    "release:gate": "npx -y tsx scripts/release-gate.ts",
    "verify": "npm run typecheck && npm run selftest && npm run test:save && npm run balance:sim && npm run release:audit && npm run build"
  },
  "devDependencies": {
    "gh-pages": "^6.3.0",
    "typescript": "^5.4.0",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
