{
  "name": "praesidium",
  "version": "0.1.0",
  "description": "Praesidium — a super large-scale tower defense game (web)",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "selftest": "npx -y tsx scripts/selftest.ts",
    "test:save": "npx -y tsx scripts/save-restore-test.ts",
    "balance:sim": "npx -y tsx scripts/balance-sim.ts",
    "verify": "npm run typecheck && npm run selftest && npm run test:save && npm run balance:sim && npm run build"
  },
  "devDependencies": {
    "gh-pages": "^6.3.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vitest": "^2.1.8"
  }
}
